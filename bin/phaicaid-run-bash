#!/usr/bin/env bash
# Ultra-lightweight hook runner — pure bash + socat, no interpreter startup.
set -euo pipefail

EVENT=""
TARGET=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --event) EVENT="$2"; shift 2 ;;
    --target) TARGET="$2"; shift 2 ;;
    *) shift ;;
  esac
done

if [[ -z "$EVENT" ]]; then
  echo "usage: phaicaid-run-bash --event <event> [--target <target>]" >&2
  exit 1
fi

RTDIR="$(pwd)/.phaicaid"
SOCK="$RTDIR/run/phaicaid.sock"

# Read stdin payload
STDIN_DATA=""
if [[ ! -t 0 ]]; then
  STDIN_DATA=$(cat)
fi

if [[ -z "$STDIN_DATA" || "$STDIN_DATA" == "{}" ]]; then
  PAYLOAD='{}'
else
  PAYLOAD="$STDIN_DATA"
fi

# Prefer jq for safe JSON construction; fall back to string interpolation.
if command -v jq >/dev/null 2>&1; then
  MSG=$(jq -nc \
    --arg event "$EVENT" \
    --arg target "$TARGET" \
    --argjson payload "$PAYLOAD" \
    '{"op":"hook","raw":true,"data":{"__event":$event,"__target":$target,"__payload":$payload}}')
else
  MSG="{\"op\":\"hook\",\"raw\":true,\"data\":{\"__event\":\"$EVENT\",\"__target\":\"$TARGET\",\"__payload\":$PAYLOAD}}"
fi

echo "$MSG" | socat - UNIX-CONNECT:"$SOCK"
